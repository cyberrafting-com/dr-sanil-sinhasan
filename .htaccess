<Files ~ "^.*\.([Ee][Nn][Vv])">
 order allow,deny
 deny from all
 satisfy all
</Files>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect www to non-www
    RewriteCond %{HTTP_HOST} ^www\.drsanilsinhasan\.com$ [NC]
    RewriteRule ^(.*)$ https://drsanilsinhasan.com/$1 [L,R=301]

   

    # Forward everything to public/ folder
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ /public/$1 [L]

</IfModule>

# Old PHP page redirects
Redirect 301 /about.php https://drsanilsinhasan.com/about
Redirect 301 /depression-psychosis.php https://drsanilsinhasan.com/services/depression-psychosis
Redirect 301 /counselling.php https://drsanilsinhasan.com/services/counselling
Redirect 301 /childhood-problems.php https://drsanilsinhasan.com/services/childhood-problems
Redirect 301 /anxiety-disorder.php https://drsanilsinhasan.com/services/anxiety-disorder
Redirect 301 /deaddiction.php https://drsanilsinhasan.com/services/deaddiction
Redirect 301 /patient-info.php https://drsanilsinhasan.com/gallery/videos

# php -- BEGIN cPanel-generated handler, do not edit
